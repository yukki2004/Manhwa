{
  "ConnectionStrings": {
    "DefaultConnection": "Host=your_db_host;Port=5432;Database=manhwa;Username=postgres;Password=YOUR_DB_PASSWORD"
  },
  "Jwt": {
    "Key": "YOUR_SECRET_KEY_MIN_32_CHARS_LONG",
    "Issuer": "ManhwaBackend",
    "Audience": "ManhwaClients",
    "DurationInMinutes": 15,
    "RefreshTokenDurationInDays": 7
  },
  "RabbitMqSettings": {
    "Host": "rabbitmq",
    "UserName": "guest",
    "Password": "guest"
  },
  "RedisSettings": {
    "Host": "your_redis_host",
    "Port": 12574,
    "User": "default",
    "Password": "YOUR_REDIS_PASSWORD",
    "InstanceName": "Manhwa_"
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "manhwa",
    "SenderEmail": "your_email@gmail.com",
    "Password": "YOUR_GMAIL_APP_PASSWORD"
  },
  "FileStorage": {
    "RootPath": "/app/storage",
    "BaseUrl": "https://cdn.truyenverse.top/files",
    "Provider": "R2"
  },
  "CloudflareR2": {
    "AccountId": "YOUR_ACCOUNT_ID",
    "AccessKeyId": "YOUR_ACCESS_KEY",
    "SecretAccessKey": "YOUR_SECRET_ACCESS_KEY",
    "BucketName": "truyen-verse",
    "ServiceUrl": "https://your_account_id.r2.cloudflarestorage.com"
  },
  "ApiBaseUrl": "https://cdn.truyenverse.top",
  "Google": {
    "ClientId": "YOUR_GOOGLE_CLIENT_ID"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}